PORT=3000
NODE_ENV=production
EDITOR_USERNAME=Topaze
EDITOR_PASSWORD=Mera
DATA_DIR=/app/data
# Port local sur le serveur pour Nginx (ne pas toucher si vous utilisez docker-compose.nginx.yml)
APP_PORT=3050
# Cles VAPID pour les notifications Web Push (generer avec: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@example.com
